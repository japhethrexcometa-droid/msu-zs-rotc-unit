# ─────────────────────────────────────────────────────────────────────────────
# MSU-ZS ROTC ATTENDANCE SYSTEM — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Digital ID Public Portal ──────────────────────────────────────────────────
# This is the public web URL where cadets can search and view their digital ID.
# OPTION A: If you deploy the web version (expo export --platform web + hosting):
#   Set this to your real deployed URL, e.g. https://rotc-mszs.netlify.app
# OPTION B: If you only publish the mobile APK (no web):
#   Leave this empty — the app will auto-generate a deep link (exp:// or your scheme)
#   that works on any device with the app installed.
VITE_DIGITAL_ID_PORTAL_URL=https://rotc1-eight.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Use remote Supabase (0 = remote/production, 1 = local dev)
VITE_USE_LOCAL_SUPABASE=1
# VITE_LOCAL_SUPABASE_URL=http://192.168.1.xxx:54321
# VITE_LOCAL_SUPABASE_ANON_KEY=sb_publishable_YOUR_LOCAL_KEY_HERE

# Supabase Remote Credentials (publishable — safe for client bundles)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Server-side scan: use atomic PostgreSQL RPC instead of client-side logic
# Set to 1 to enable, 0 to use existing client-side scan (default: 0)
VITE_USE_SERVER_SCAN=0

# Real-time dashboard: live attendance counters via Supabase Realtime
# Set to 1 to enable, 0 to use polling fallback (default: 0)
VITE_ENABLE_REALTIME=0

# Duty Officer Dashboard: session schedule + request open session
# Set to 1 to enable, 0 to disable (default: 0)
VITE_ENABLE_DUTY_DASHBOARD=0

# Cadet Notifications: live session banners + notification sounds
# Set to 1 to enable, 0 to disable (default: 0)
VITE_ENABLE_CADET_NOTIFICATIONS=0

# Unit Hierarchy: battalion/company/platoon tree management
# Set to 1 to enable, 0 to disable (default: 0)
VITE_ENABLE_UNIT_HIERARCHY=0

